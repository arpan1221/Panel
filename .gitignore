# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
*.egg-info/
.ipynb_checkpoints/

# Node / Next
node_modules/
.next/
out/
dist/
*.tsbuildinfo

# Environments
.env
.env.local
.env.*.local

# Agent runtime artifacts (per-experiment scratch)
/runs/
*.jsonl.tmp
notebook_scratch.ipynb

# Plots/artifacts dropped in repo root by agent cells without an out-dir
/profiling.png
/*.png

# VS Code extension builds
extension/out/
extension/*.vsix

# OS
.DS_Store
Thumbs.db

# Claude Design handoff bundle (scratch, not part of project)
/panel/

# Logs
*.log
npm-debug.log*

# Supabase local
supabase/.temp/

# Claude Code / plugin auto-installs (per-machine tooling, not product code).
# Keep our intentional meta-agents at .claude/agents/{spec-keeper,schema-guard,demo-auditor}.md
# but ignore everything else auto-installed in .claude/ and all of .agents/.
/.agents/
/.planning/
/skills-lock.json
/.claude/*
!/.claude/agents/
/.claude/agents/gsd-*

# Allow examples to keep their data, but not agent-generated plots dropped there
!examples/**/data/
examples/*/data/*.png
